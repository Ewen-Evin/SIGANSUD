{% extends 'base.html.twig' %}

{% block title %}{{ action }} un menu - SIGEANSUD{% endblock %}

{% block body %}
<a href="{{ path('menu_index') }}" class="btn btn-secondary btn-sm mb-3">
    <i class="bi bi-arrow-left"></i> Retour aux menus
</a>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <h4 class="mb-0"><i class="bi bi-cup-straw"></i> {{ action }} un menu</h4>
            </div>
            <div class="card-body">
                <form method="post">
                    <div class="mb-3">
                        <label for="aliment" class="form-label">Aliment</label>
                        <input type="text" class="form-control" id="aliment" name="aliment"
                               value="{{ menu ? menu.aliment : '' }}" required
                               placeholder="Ex: Viande de boeuf">
                    </div>
                    <div class="mb-3">
                        <label for="quantite" class="form-label">Quantite (kg)</label>
                        <input type="number" class="form-control" id="quantite" name="quantite"
                               value="{{ menu ? menu.quantite : '' }}" required min="1"
                               placeholder="Ex: 5">
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg"></i> {{ action }}
                        </button>
                        <a href="{{ path('menu_index') }}" class="btn btn-secondary">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
