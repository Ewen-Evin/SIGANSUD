{% extends 'base.html.twig' %}

{% block title %}Menus - SIGEANSUD{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-cup-straw"></i> Menus</h2>
    <a href="{{ path('menu_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Ajouter un menu
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Aliment</th>
                        <th>Quantite (kg)</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for menu in menus %}
                    <tr>
                        <td>{{ menu.id }}</td>
                        <td><strong>{{ menu.aliment }}</strong></td>
                        <td>{{ menu.quantite }}</td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a href="{{ path('menu_edit', {id: menu.id}) }}"
                                   class="btn btn-warning" title="Modifier">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" action="{{ path('menu_delete', {id: menu.id}) }}"
                                      style="display:inline"
                                      onsubmit="return confirm('Supprimer ce menu ?')">
                                    <button type="submit" class="btn btn-sm btn-danger" title="Supprimer">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">Aucun menu enregistre.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
