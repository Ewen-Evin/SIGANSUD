{% extends 'base.html.twig' %}

{% block title %}Accueil - SIGEANSUD{% endblock %}

{% block body %}
<div class="text-center mb-5">
    <h1><i class="bi bi-tree hero-icon"></i></h1>
    <h2>Back-office SIGEANSUD</h2>
    <p class="text-muted">Gestion du parc animalier</p>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card text-center p-4">
            <div class="card-body">
                <i class="bi bi-people hero-icon"></i>
                <h3 class="mt-3">{{ nbSoignants }}</h3>
                <p class="text-muted">Soignants</p>
                <a href="{{ path('soignant_index') }}" class="btn btn-primary">Gerer</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center p-4">
            <div class="card-body">
                <i class="bi bi-bug hero-icon"></i>
                <h3 class="mt-3">{{ nbEspeces }}</h3>
                <p class="text-muted">Especes</p>
                <a href="{{ path('espece_index') }}" class="btn btn-primary">Consulter</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center p-4">
            <div class="card-body">
                <i class="bi bi-cup-straw hero-icon"></i>
                <h3 class="mt-3">{{ nbMenus }}</h3>
                <p class="text-muted">Menus</p>
                <a href="{{ path('menu_index') }}" class="btn btn-primary">Gerer</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
