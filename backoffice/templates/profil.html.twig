{% extends 'base.html.twig' %}

{% block title %}Mon profil - SIGEANSUD{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header text-center py-4">
                <div class="d-inline-flex align-items-center justify-content-center bg-primary text-white rounded-circle"
                     style="width: 80px; height: 80px; font-size: 2rem;">
                    {{ gestionnaire.prenom|first }}{{ gestionnaire.nom|first }}
                </div>
                <h4 class="mt-3 mb-0">{{ gestionnaire.prenom }} {{ gestionnaire.nom }}</h4>
                <span class="badge {{ gestionnaire.role == 'admin' ? 'bg-danger' : 'bg-primary' }} mt-2">
                    {{ gestionnaire.role|capitalize }}
                </span>
            </div>
            <div class="card-body">
                <form method="post">
                    <div class="mb-3">
                        <label for="login" class="form-label">Login</label>
                        <input type="text" class="form-control" id="login" value="{{ gestionnaire.login }}" readonly disabled>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="nom" class="form-label">Nom</label>
                            <input type="text" class="form-control" id="nom" name="nom"
                                   value="{{ gestionnaire.nom }}" required>
                        </div>
                        <div class="col-md-6">
                            <label for="prenom" class="form-label">Prenom</label>
                            <input type="text" class="form-control" id="prenom" name="prenom"
                                   value="{{ gestionnaire.prenom }}" required>
                        </div>
                    </div>
                    <div class="mt-3">
                        <label for="mot_de_passe" class="form-label">Nouveau mot de passe</label>
                        <input type="password" class="form-control" id="mot_de_passe" name="mot_de_passe"
                               placeholder="Laisser vide pour ne pas changer">
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg"></i> Enregistrer
                        </button>
                        <a href="{{ path('dashboard') }}" class="btn btn-secondary">Retour</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
