{% extends 'base.html.twig' %}

{% block title %}{{ action }} une espece - SIGEANSUD{% endblock %}

{% block body %}
<a href="{{ path('espece_index') }}" class="btn btn-secondary btn-sm mb-3">
    <i class="bi bi-arrow-left"></i> Retour aux especes
</a>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <h4 class="mb-0"><i class="bi bi-bug"></i> {{ action }} une espece</h4>
            </div>
            <div class="card-body">
                <form method="post">
                    <div class="mb-3">
                        <label for="nom" class="form-label">Nom de l'espece</label>
                        <input type="text" class="form-control" id="nom" name="nom"
                               value="{{ espece ? espece.nom : '' }}" required
                               placeholder="Ex: Lion">
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg"></i> {{ action }}
                        </button>
                        <a href="{{ path('espece_index') }}" class="btn btn-secondary">Annuler</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
