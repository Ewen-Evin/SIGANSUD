{% extends 'base.html.twig' %}

{% block title %}Animaux - {{ espece.nom }} - SIGEANSUD{% endblock %}

{% block body %}
<a href="{{ path('espece_index') }}" class="btn btn-secondary btn-sm mb-3">
    <i class="bi bi-arrow-left"></i> Retour aux especes
</a>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-bug"></i> Animaux - {{ espece.nom }}</h2>
    <a href="{{ path('espece_animal_new', {id: espece.id}) }}" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Ajouter un animal
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Nom de bapteme</th>
                        <th>Date de naissance</th>
                        <th>Genre</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for animal in animaux %}
                    <tr>
                        <td><strong>{{ animal.nomBapteme }}</strong></td>
                        <td>{{ animal.dateNaissance ?? '-' }}</td>
                        <td>
                            {% if animal.genre == 'M' %}
                                <span class="badge bg-primary">Male</span>
                            {% else %}
                                <span class="badge bg-danger">Femelle</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if animal.dateDeces %}
                                <span class="badge bg-secondary">Decede ({{ animal.dateDeces }})</span>
                            {% else %}
                                <span class="badge bg-success">Vivant</span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a href="{{ path('espece_animal_edit', {id: espece.id, nomBapteme: animal.nomBapteme}) }}"
                                   class="btn btn-warning" title="Modifier">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" action="{{ path('espece_animal_delete', {id: espece.id, nomBapteme: animal.nomBapteme}) }}"
                                      style="display:inline"
                                      onsubmit="return confirm('Supprimer cet animal ?')">
                                    <button type="submit" class="btn btn-sm btn-danger" title="Supprimer">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">Aucun animal pour cette espece.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
