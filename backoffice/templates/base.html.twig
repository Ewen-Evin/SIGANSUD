<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}SIGEANSUD - Back-office{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; }
        .navbar { background-color: #2c3e50 !important; }
        .navbar-brand { font-weight: bold; color: #f39c12 !important; }
        .nav-link { color: rgba(255,255,255,0.8) !important; }
        .nav-link:hover, .nav-link.active { color: #f39c12 !important; }
        .card { border: none; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        .btn-primary { background-color: #2c3e50; border-color: #2c3e50; }
        .btn-primary:hover { background-color: #34495e; border-color: #34495e; }
        .btn-warning { color: #fff; }
        .table th { background-color: #2c3e50; color: white; }
        .hero-icon { font-size: 3rem; color: #f39c12; }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="{{ path('dashboard') }}">
                <i class="bi bi-tree"></i> SIGEANSUD
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link {% if app.request.attributes.get('_route') == 'dashboard' %}active{% endif %}"
                           href="{{ path('dashboard') }}">
                            <i class="bi bi-house"></i> Accueil
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {% if 'soignant' in app.request.attributes.get('_route', '') %}active{% endif %}"
                           href="{{ path('soignant_index') }}">
                            <i class="bi bi-people"></i> Soignants
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {% if 'espece' in app.request.attributes.get('_route', '') %}active{% endif %}"
                           href="{{ path('espece_index') }}">
                            <i class="bi bi-bug"></i> Especes
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {% if 'menu' in app.request.attributes.get('_route', '') %}active{% endif %}"
                           href="{{ path('menu_index') }}">
                            <i class="bi bi-cup-straw"></i> Menus
                        </a>
                    </li>
                    {% if app.session.get('gestionnaire') and app.session.get('gestionnaire').role == 'admin' %}
                    <li class="nav-item">
                        <a class="nav-link {% if 'gestionnaire' in app.request.attributes.get('_route', '') %}active{% endif %}"
                           href="{{ path('gestionnaire_index') }}">
                            <i class="bi bi-shield-lock"></i> Gestionnaires
                        </a>
                    </li>
                    {% endif %}
                </ul>
                {% if app.session.get('gestionnaire') %}
                <ul class="navbar-nav ms-3">
                    <li class="nav-item">
                        <span class="nav-link">
                            <i class="bi bi-person-circle"></i>
                            {{ app.session.get('gestionnaire').prenom }}
                        </span>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('logout') }}">
                            <i class="bi bi-box-arrow-right"></i> Deconnexion
                        </a>
                    </li>
                </ul>
                {% endif %}
            </div>
        </div>
    </nav>

    <div class="container mb-5">
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ type }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}

        {% block body %}{% endblock %}
    </div>

    <footer class="bg-dark text-white text-center py-3 mt-auto">
        <small>&copy; 2026 SIGEANSUD - Parc animalier</small>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    {% block javascripts %}{% endblock %}
</body>
</html>
