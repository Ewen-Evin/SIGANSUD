{% extends 'base.html.twig' %}

{% block title %}Soignants - SIGEANSUD{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-people"></i> Soignants</h2>
    <a href="{{ path('soignant_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Ajouter un soignant
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Matricule</th>
                        <th>Nom</th>
                        <th>Prenom</th>
                        <th>Telephone</th>
                        <th class="d-none d-md-table-cell">Adresse</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for soignant in soignants %}
                    <tr>
                        <td><strong>{{ soignant.matricule }}</strong></td>
                        <td>{{ soignant.nom }}</td>
                        <td>{{ soignant.prenom }}</td>
                        <td>{{ soignant.tel ?? '-' }}</td>
                        <td class="d-none d-md-table-cell">{{ soignant.adresse ?? '-' }}</td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <a href="{{ path('soignant_especes', {matricule: soignant.matricule}) }}"
                                   class="btn btn-info" title="Especes">
                                    <i class="bi bi-bug"></i>
                                </a>
                                <a href="{{ path('soignant_edit', {matricule: soignant.matricule}) }}"
                                   class="btn btn-warning" title="Modifier">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" action="{{ path('soignant_delete', {matricule: soignant.matricule}) }}"
                                      style="display:inline"
                                      onsubmit="return confirm('Supprimer ce soignant ?')">
                                    <button type="submit" class="btn btn-sm btn-danger" title="Supprimer">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">Aucun soignant enregistre.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
