{% extends 'base.html.twig' %}

{% block title %}Especes de {{ soignant.prenom }} {{ soignant.nom }} - SIGEANSUD{% endblock %}

{% block body %}
<div class="mb-4">
    <a href="{{ path('soignant_index') }}" class="btn btn-secondary btn-sm">
        <i class="bi bi-arrow-left"></i> Retour aux soignants
    </a>
</div>

<h2><i class="bi bi-bug"></i> Especes de {{ soignant.prenom }} {{ soignant.nom }}</h2>
<p class="text-muted">Matricule : {{ soignant.matricule }} | Maximum 3 especes par soignant</p>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Especes affectees ({{ especesAffectees|length }}/3)</h5>
            </div>
            <div class="card-body">
                {% if especesAffectees|length > 0 %}
                    {% for espece in especesAffectees %}
                    <div class="d-flex justify-content-between align-items-center mb-2 p-2 bg-light rounded">
                        <span><i class="bi bi-check-circle text-success"></i> {{ espece.nom }}</span>
                        <form method="post" style="display:inline">
                            <input type="hidden" name="action" value="retirer">
                            <input type="hidden" name="espece_id" value="{{ espece.id }}">
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    onclick="return confirm('Retirer cette espece ?')">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </form>
                    </div>
                    {% endfor %}
                {% else %}
                    <p class="text-muted text-center">Aucune espece affectee.</p>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card">
            <div class="card-header bg-secondary text-white">
                <h5 class="mb-0">Especes disponibles</h5>
            </div>
            <div class="card-body">
                {% if especesAffectees|length >= 3 %}
                    <div class="alert alert-warning mb-0">
                        <i class="bi bi-exclamation-triangle"></i> Maximum atteint (3 especes).
                    </div>
                {% elseif especesDisponibles|length > 0 %}
                    {% for espece in especesDisponibles %}
                    <div class="d-flex justify-content-between align-items-center mb-2 p-2 bg-light rounded">
                        <span>{{ espece.nom }}</span>
                        <form method="post" style="display:inline">
                            <input type="hidden" name="action" value="affecter">
                            <input type="hidden" name="espece_id" value="{{ espece.id }}">
                            <button type="submit" class="btn btn-sm btn-outline-success">
                                <i class="bi bi-plus-lg"></i> Affecter
                            </button>
                        </form>
                    </div>
                    {% endfor %}
                {% else %}
                    <p class="text-muted text-center">Toutes les especes sont deja affectees.</p>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
